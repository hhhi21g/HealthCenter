  "diseases": [
    {
      "name": "流感",
      "category": "呼吸道传染病",
      "summary": "以发热、咳嗽、咽痛、肌肉酸痛等为常见表现，老人、儿童和慢病患者应重点防护。",
      "actions": ["保持室内通风", "咳嗽或发热时减少聚集", "按建议接种流感疫苗", "出现持续高热或呼吸困难及时就医"],
      "links": ["/knowledge"]
    },
    {
      "name": "肺结核",
      "category": "呼吸道传染病",
      "summary": "常见症状包括持续咳嗽、咳痰、低热、盗汗等，规范筛查和治疗很重要。",
      "actions": ["长期咳嗽咳痰应主动筛查", "居室保持通风", "治疗期间遵医嘱规范用药", "密切接触者按要求检查"],
      "links": ["/knowledge", "/chest-diagnosis"]
    },
    {
      "name": "诺如病毒感染",
      "category": "消化道与食源性疾病",
      "summary": "常引起呕吐、腹泻等胃肠道症状，学校、托幼机构和集体场所需加强手卫生。",
      "actions": ["饭前便后洗手", "呕吐物和污染物规范清理", "生熟食品分开处理", "症状明显时及时补液并就医"],
      "links": ["/knowledge"]
    },
    {
      "name": "食物中毒",
      "category": "消化道与食源性疾病",
      "summary": "多与食品储存、加工、交叉污染有关，夏季和集体用餐场景更需要注意。",
      "actions": ["熟食充分加热", "生熟分开", "剩菜及时冷藏并彻底复热", "外出就餐选择卫生条件较好的场所"],
      "links": ["/knowledge"]
    },
    {
      "name": "登革热",
      "category": "蚊媒与虫媒疾病",
      "summary": "通过蚊虫叮咬传播，预防重点是清除积水和避免蚊虫叮咬。",
      "actions": ["清理居家和周边积水", "安装纱窗纱门", "户外活动使用驱蚊用品", "发热伴皮疹或肌痛时及时就医"],
      "links": ["/knowledge"]
    },
    {
      "name": "中暑",
      "category": "季节性健康风险",
      "summary": "高温、高湿、强体力活动时风险增加，老人、儿童和户外劳动者应重点防护。",
      "actions": ["避开高温时段户外活动", "及时补水和补充电解质", "出现头晕乏力时转移到阴凉处", "意识异常或高热时立即就医"],
      "links": ["/water-intake", "/emergency-guide"]
    },
    {
      "name": "高血压",
      "category": "慢性病预防",
      "summary": "高血压管理重在长期监测、生活方式干预和规范用药。",
      "actions": ["定期测量血压", "减少盐摄入", "坚持规律运动", "遵医嘱服药并复诊"],
      "links": ["/heart-diagnosis", "/knowledge"]
    },
    {
      "name": "糖尿病",
      "category": "慢性病预防",
      "summary": "糖尿病防控需要关注体重、饮食、运动、血糖监测和并发症筛查。",
      "actions": ["控制总能量摄入", "规律运动", "监测血糖", "关注足部和眼底等并发症筛查"],
      "links": ["/diabetes-diagnosis", "/bmi"]
    },
    {
      "name": "冠心病",
      "category": "慢性病预防",
      "summary": "胸痛、胸闷、活动后不适等症状需要重视，控制血压、血脂和血糖有助于降低风险。",
      "actions": ["戒烟限酒", "控制血压血脂血糖", "规律运动并避免过度劳累", "突发胸痛及时就医"],
      "links": ["/heart-diagnosis", "/emergency-guide"]
    },
    {
      "name": "慢阻肺",
      "category": "慢性病预防",
      "summary": "慢性咳嗽、咳痰、气短应关注肺功能检查，吸烟人群尤其需要防护。",
      "actions": ["戒烟并远离二手烟", "减少粉尘和刺激性气体暴露", "规律复诊", "按建议接种相关疫苗"],
      "links": ["/chest-diagnosis", "/knowledge"]
    },
    {
      "name": "肥胖",
      "category": "重点人群健康",
      "summary": "肥胖与多种慢性病风险相关，体重管理应结合饮食、运动、睡眠和长期习惯。",
      "actions": ["记录体重和腰围", "减少高糖高脂饮食", "保证睡眠", "每周保持规律身体活动"],
      "links": ["/bmi", "/sleep-quality"]
    },
    {
      "name": "骨质疏松",
      "category": "重点人群健康",
      "summary": "老年人和绝经后女性更应关注骨健康，跌倒预防和骨密度筛查很重要。",
      "actions": ["适量日晒", "补充钙和维生素D", "进行抗阻和平衡训练", "居家减少跌倒隐患"],
      "links": ["/knowledge"]
    }
